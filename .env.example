# -----------------------------------------------------------------------------
# LPNU API Load Test Environment Variables
# Copy this file to .env and adjust the values as needed.
# -----------------------------------------------------------------------------

# --- Authentication (Keycloak) ---
AUTH_BASE_URL=https://vm4-dev-dto.lviv.education/realms/master
KEYCLOAK_CLIENT_ID=my-university-client
# Provide a secret if your Keycloak client is confidential
KEYCLOAK_CLIENT_SECRET=

# --- Target APIs ---
STUDENT_API_BASE_URL=https://vm4-dev-dto.lviv.education/student/api
NEWS_BASE_URL=https://lpnu.ua

# --- Load Testing Profile ---
# Global defaults (can be overridden by stages below)
VUS=10
DURATION=1m

# Stage 1: Warm-up
STAGE1_DURATION=10s
STAGE1_TARGET=5

# Stage 2: Steady State
STAGE2_DURATION=30s
STAGE2_TARGET=10

# Stage 3: Cool-down
STAGE3_DURATION=10s
STAGE3_TARGET=0
